LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-with-secret
LIVEKIT_API_SECRET=replace-with-secret
OPENAI_API_KEY=replace-with-secret
ASSEMBLYAI_API_KEY=replace-with-secret
CARTESIA_API_KEY=replace-with-secret

GCP_PROJECT_ID=ai-agent-staging-490002
FIRESTORE_DATABASE=staging
TRANSCRIPTS_BUCKET=ai-agent-staging-490002-calls

# Worker identity used by trigger's agent_name_livekit mapping
WORKER_AGENT_NAME=verifacto-outbound-agent

# Runtime defaults
LK_TTS_PROVIDER=cartesia
LK_USE_TURN_HANDLING=true
LK_PREEMPTIVE_GENERATION=true
LK_LOW_LATENCY_MODE=true
OPENAI_MODEL=gpt-4o-mini

